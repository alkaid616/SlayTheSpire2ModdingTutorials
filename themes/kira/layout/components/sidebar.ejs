<div class="kira-sidebar" id="sidebar">
	<div class="kira-avatar mdui-ripple">
		<a href="<%= theme.avatar %>" title="<%= config.author || config.title %>">
			<img src="<%= theme.avatar %>" alt="<%= config.author || config.title %>" />
		</a>
	</div>
	<div class="kira-count">
		<div><span>文章</span>
			<%= site.posts.length %>
		</div>
		<div><span>标签</span>
			<%= site.tags.length %>
		</div>
		<div><span>分类</span>
			<%= site.categories.length %>
		</div>
	</div>
	<button type="button" class="kira-panel-reopen" id="kira-sidebar-reopen" hidden title="展开导航" aria-label="展开导航">
		<i class="kirafont icon-caret-up kira-reopen-icon" aria-hidden="true"></i>
	</button>
	<div class="kira-sidebar-inner">
		<div class="kira-sidebar-top">
			<div class="kira-search-panel">
				<div class="kira-search-input-wrap">
					<i class="kirafont icon-search"></i>
					<input id="kira-search-input" type="search" placeholder="搜索全部文章内容..." autocomplete="off" />
				</div>
				<div id="kira-search-results" class="kira-search-results" hidden></div>
			</div>
			<button type="button" class="kira-collapse-toggle" id="kira-sidebar-collapse" aria-expanded="true" aria-controls="kira-sidebar-scroll" title="折叠导航" aria-label="折叠导航">
				<i class="kirafont icon-caret-up kira-collapse-icon" aria-hidden="true"></i>
			</button>
		</div>
		<div class="kira-sidebar-scroll kira-scrollbar" id="kira-sidebar-scroll">
	<div class="kira-list kira-docs-tree kira-explorer">
		<% if (theme.docsTree && theme.docsTree.length) { %>
			<ul class="kira-explorer-list kira-explorer-root">
				<% var nodeCounter=0; function renderExplorer(nodes, level) { (nodes || []).forEach(function(node) { var
					hasChildren=!!(node.children && node.children.length); var isOpen=node.open !==false; nodeCounter
					+=1; var nodeId='tree-node-' + level + '-' + nodeCounter; var nodePath=node.path ? (node.path==='/'
					? node.path : node.path.replace(/^\/+/, '' )) : '' ; var isActive=node.path &&
					String(is_current(node.path))==='true' ; %>
					<li class="kira-explorer-node <%= hasChildren ? 'is-folder' : 'is-file' %> <%= isOpen ? 'is-open' : '' %> <%= isActive ? 'is-active' : '' %>"
						data-level="<%= level %>" data-node-id="<%= nodeId %>" style="--node-order:<%= nodeCounter %>;">
						<div class="kira-explorer-row">
							<% if (hasChildren) { %>
								<button class="kira-explorer-toggle" type="button"
									aria-expanded="<%= isOpen ? 'true' : 'false' %>" aria-controls="<%= nodeId %>">
									<span class="kira-explorer-caret"></span>
								</button>
								<% } else { %>
									<span class="kira-explorer-toggle-spacer"></span>
									<% } %>

										<% if (node.path) { %>
											<a class="kira-explorer-link mdui-ripple"
												href="<%- url_for(nodePath, { relative: true }) -%>"
												title="<%= node.title %>">
												<i
													class="kirafont <%= node.icon || (hasChildren ? 'icon-folder' : 'icon-file') %>"></i>
												<span class="kira-explorer-text">
													<%= node.title %>
												</span>
											</a>
											<% } else { %>
												<span class="kira-explorer-link is-label" title="<%= node.title %>">
													<i
														class="kirafont <%= node.icon || (level === 0 ? 'icon-book' : 'icon-folder') %>"></i>
													<span class="kira-explorer-text">
														<%= node.title %>
													</span>
												</span>
												<% } %>
						</div>

						<% if (hasChildren) { %>
							<div class="kira-explorer-children" id="<%= nodeId %>">
								<ul class="kira-explorer-list">
									<% renderExplorer(node.children, level + 1); %>
								</ul>
							</div>
							<% } %>
					</li>
					<% }); } renderExplorer(theme.docsTree, 0); %>
			</ul>
			<div class="kira-explorer-hover-indicator" aria-hidden="true"></div>
			<% } else { %>
				<% for (name in theme.menu) { %>
					<a class="kira-list-item mdui-ripple <%= is_current(theme.menu[name][0]) %>"
						href="<%- url_for(theme.menu[name][0]) -%>" title="<%= name %>">
						<i class="kirafont
						<% if (theme.menu[name][1]) { %>
							<%= theme.menu[name][1] %>
						<% } else { %>
							<%= 'icon-unordered-list' %>
						<% } %>"></i>
						<div class="kira-list-item-content">
							<%= name %>
						</div>
					</a>
					<% } %>
						<% } %>
	</div>
	<aside id="kira-sidebar">
		<% theme.widgets.forEach(function(widget) {%>
			<%- partial('_widget/' + widget) %>
				<% }) %>
	</aside>
	<% if (!theme.busuanzi || theme.busuanzi.active !==false) { %>
		<div class="kira-widget-wrap kira-widget-busuanzi">
			<h3 class="kira-widget-title">
				<%= (theme.busuanzi && theme.busuanzi.title) || '访客统计' %>
			</h3>
			<div class="kira-widget kira-busuanzi-stats">
				<div class="kira-busuanzi-item" id="busuanzi_container_site_pv">
					<span class="kira-busuanzi-label">总访问</span>
					<span class="kira-busuanzi-value" id="busuanzi_value_site_pv"></span>
				</div>
				<div class="kira-busuanzi-item" id="busuanzi_container_site_uv">
					<span class="kira-busuanzi-label">总访客</span>
					<span class="kira-busuanzi-value" id="busuanzi_value_site_uv"></span>
				</div>
				<div class="kira-busuanzi-item" id="busuanzi_container_page_pv">
					<span class="kira-busuanzi-label">本文阅读</span>
					<span class="kira-busuanzi-value" id="busuanzi_value_page_pv"></span>
				</div>
			</div>
			<script defer src="//busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"></script>
		</div>
		<% } %>
			<div class="kira-copyright">
				&copy; <%= date(new Date(), 'YYYY' ) %>
					<a href="<%- url_for('/') %>">
						<%= config.author || config.title %>
					</a>
					<%= __('Powered by') %> <a href="http://hexo.io/" target="_blank">Hexo</a> &
						<a href="https://github.com/ch1ny/kira-hexo/" target="_blank">Kira-Hexo</a>
						<br />
						<% if (theme.beian) { %>
							<a href="https://beian.miit.gov.cn/" target="_blank">
								<%= theme.beian %>
							</a>
							<% } %>
								<%- theme.sidebar %>
			</div>
		</div>
	</div>
</div>
<div class="kira-sidebar-modal" id="sidebar-modal" onclick="(function(self) {
		self.classList.remove('show');
		document.querySelector('.kira-sidebar.show#sidebar').classList.remove('show');
	})(this)"></div>
<script>
	(function () {
		var tree = document.querySelector('.kira-docs-tree.kira-explorer');
		if (!tree) return;

		var folders = tree.querySelectorAll('.kira-explorer-node.is-folder');
		var indicator = tree.querySelector('.kira-explorer-hover-indicator');
		var foldAnimTimer = null;
		var storageKey = 'kira:docs-tree:open-state';
		var sidebarScrollKey = 'kira:sidebar-scroll-top';
		var sidebarScroll = document.getElementById('kira-sidebar-scroll');
		var storedFolderState = readFolderState();

		function saveSidebarScroll() {
			if (!sidebarScroll || !window.localStorage) return;
			try {
				localStorage.setItem(sidebarScrollKey, String(sidebarScroll.scrollTop));
			} catch (error) {}
		}

		function restoreSidebarScroll() {
			if (!sidebarScroll || !window.localStorage) return;
			try {
				var raw = localStorage.getItem(sidebarScrollKey);
				if (raw == null) return;
				var top = parseInt(raw, 10);
				if (!isNaN(top) && top >= 0) sidebarScroll.scrollTop = top;
			} catch (error) {}
		}

		function readFolderState() {
			try {
				var raw = window.localStorage ? localStorage.getItem(storageKey) : null;
				return raw ? JSON.parse(raw) : null;
			} catch (error) {
				return null;
			}
		}

		function writeFolderState() {
			try {
				if (!window.localStorage) return;
				var state = {};
				folders.forEach(function (folder) {
					var nodeId = folder.getAttribute('data-node-id');
					if (nodeId) state[nodeId] = folder.classList.contains('is-open');
				});
				localStorage.setItem(storageKey, JSON.stringify(state));
			} catch (error) {
			}
		}

		function getChildrenBox(folder) {
			return folder.querySelector(':scope > .kira-explorer-children');
		}

		function updateChildrenHeight(folder) {
			var box = getChildrenBox(folder);
			if (!box) return;
			box.style.setProperty('--children-height', box.scrollHeight + 'px');
		}

		function refreshAncestorHeights(fromNode) {
			var cursor = fromNode;
			while (cursor && cursor !== tree) {
				if (cursor.classList && cursor.classList.contains('kira-explorer-node') && cursor.classList.contains('is-folder')) {
					updateChildrenHeight(cursor);
				}
				cursor = cursor.parentElement;
			}
		}

		function refreshAllFolderHeights() {
			Array.prototype
				.slice.call(folders)
				.sort(function (a, b) {
					return Number(b.getAttribute('data-level') || 0) - Number(a.getAttribute('data-level') || 0);
				})
				.forEach(function (folder) {
					updateChildrenHeight(folder);
				});
		}

		function scheduleHeightSync() {
			refreshAllFolderHeights();
			requestAnimationFrame(function () {
				refreshAllFolderHeights();
				requestAnimationFrame(function () {
					refreshAllFolderHeights();
				});
			});
			setTimeout(refreshAllFolderHeights, 120);
			setTimeout(refreshAllFolderHeights, 360);
		}

		function triggerFoldAnimationWindow() {
			tree.classList.add('is-fold-animating');
			if (foldAnimTimer) clearTimeout(foldAnimTimer);
			foldAnimTimer = setTimeout(function () {
				tree.classList.remove('is-fold-animating');
				foldAnimTimer = null;
			}, 520);
		}

		function setFolderOpen(folder, shouldOpen, animate, persist) {
			if (!folder) return;
			if (animate) triggerFoldAnimationWindow();
			updateChildrenHeight(folder);
			folder.classList.toggle('is-open', shouldOpen);
			var btn = folder.querySelector(':scope > .kira-explorer-row .kira-explorer-toggle');
			if (btn) btn.setAttribute('aria-expanded', shouldOpen ? 'true' : 'false');
			if (persist !== false) writeFolderState();
			requestAnimationFrame(function () {
				refreshAncestorHeights(folder);
				requestAnimationFrame(function () {
					refreshAncestorHeights(folder);
				});
			});
		}

		function openAncestors(node) {
			var parent = node ? node.parentElement : null;
			while (parent && parent !== tree) {
				if (parent.classList && parent.classList.contains('kira-explorer-children')) {
					var folderNode = parent.closest('.kira-explorer-node.is-folder');
					if (folderNode) setFolderOpen(folderNode, true, false, false);
				}
				parent = parent.parentElement;
			}
		}

		folders.forEach(function (folder) {
			var nodeId = folder.getAttribute('data-node-id');
			if (storedFolderState && Object.prototype.hasOwnProperty.call(storedFolderState, nodeId)) {
				folder.classList.toggle('is-open', !!storedFolderState[nodeId]);
				var btn = folder.querySelector(':scope > .kira-explorer-row .kira-explorer-toggle');
				if (btn) btn.setAttribute('aria-expanded', storedFolderState[nodeId] ? 'true' : 'false');
			}
			updateChildrenHeight(folder);
			var children = getChildrenBox(folder);
			if (children) {
				Array.prototype.forEach.call(children.querySelectorAll(':scope > .kira-explorer-list > .kira-explorer-node'), function (child, index) {
					child.style.setProperty('--child-index', index);
				});
			}
		});

		function toggleFolderFromRow(event, row) {
			if (event.target.closest('.kira-explorer-toggle')) return;
			var folder = row.closest('.kira-explorer-node.is-folder');
			if (!folder) return;
			var link = event.target.closest('a.kira-explorer-link');
			if (link && (event.ctrlKey || event.metaKey || event.shiftKey || event.button === 1)) {
				return;
			}
			if (link && !link.classList.contains('is-label')) {
				event.preventDefault();
			}
			setFolderOpen(folder, !folder.classList.contains('is-open'), true);
		}

		tree.querySelectorAll('.kira-explorer-toggle').forEach(function (btn) {
			btn.addEventListener('click', function (event) {
				event.preventDefault();
				event.stopPropagation();
				var folder = btn.closest('.kira-explorer-node.is-folder');
				if (!folder) return;
				setFolderOpen(folder, !folder.classList.contains('is-open'), true);
			});
		});

		tree.querySelectorAll('.kira-explorer-node.is-folder > .kira-explorer-row').forEach(function (row) {
			row.addEventListener('click', function (event) {
				toggleFolderFromRow(event, row);
			});
		});

		var activeNode = tree.querySelector('.kira-explorer-node.is-active');
		if (activeNode) openAncestors(activeNode);
		scheduleHeightSync();

		tree.querySelectorAll('a.kira-explorer-link[href]').forEach(function (link) {
			link.addEventListener('click', saveSidebarScroll);
		});

		restoreSidebarScroll();
		requestAnimationFrame(function () {
			restoreSidebarScroll();
		});
		window.addEventListener('load', restoreSidebarScroll);
		window.addEventListener('pageshow', restoreSidebarScroll);
		window.addEventListener('beforeunload', saveSidebarScroll);

		function moveIndicatorTo(link, visible) {
			if (!indicator) return;
			if (!link || visible === false) {
				indicator.classList.remove('is-visible');
				return;
			}

			var rootRect = tree.getBoundingClientRect();
			var rect = link.getBoundingClientRect();
			indicator.style.setProperty('--hover-x', (rect.left - rootRect.left) + 'px');
			indicator.style.setProperty('--hover-y', (rect.top - rootRect.top) + 'px');
			indicator.style.setProperty('--hover-w', rect.width + 'px');
			indicator.style.setProperty('--hover-h', rect.height + 'px');
			indicator.classList.add('is-visible');
		}

		var activeLink = activeNode ? activeNode.querySelector(':scope > .kira-explorer-row .kira-explorer-link') : null;
		if (activeLink) moveIndicatorTo(activeLink, true);

		tree.querySelectorAll('.kira-explorer-link').forEach(function (link) {
			link.addEventListener('mouseenter', function () {
				moveIndicatorTo(link, true);
			});
		});

		tree.addEventListener('mouseleave', function () {
			if (activeLink) {
				moveIndicatorTo(activeLink, true);
				return;
			}
			moveIndicatorTo(null, false);
		});

		window.addEventListener('resize', function () {
			refreshAllFolderHeights();
			if (indicator && indicator.classList.contains('is-visible')) {
				moveIndicatorTo(activeLink, !!activeLink);
			}
		});

		window.addEventListener('load', function () {
			scheduleHeightSync();
		});

		if (document.fonts && document.fonts.ready) {
			document.fonts.ready.then(function () {
				scheduleHeightSync();
			});
		}

		if (window.ResizeObserver) {
			var resizeObserver = new ResizeObserver(function () {
				refreshAllFolderHeights();
			});
			folders.forEach(function (folder) {
				var box = getChildrenBox(folder);
				if (box) resizeObserver.observe(box);
			});
		}

	})();
</script>
<script>
	(function () {
		var input = document.getElementById('kira-search-input');
		var results = document.getElementById('kira-search-results');
		var docsTree = document.querySelector('.kira-docs-tree');
		if (!input || !results || !docsTree) return;

		var baseRoot = '<%- config.root %>';
		var indexedPosts = [];
		var loadingPromise = null;

		function escapeHtml(text) {
			return (text || '')
				.replace(/&/g, '&amp;')
				.replace(/</g, '&lt;')
				.replace(/>/g, '&gt;')
				.replace(/"/g, '&quot;')
				.replace(/'/g, '&#39;');
		}

		function normalize(text) {
			return (text || '').toLowerCase();
		}

		function resolveUrl(url) {
			if (!url) return '#';
			if (/^https?:\/\//i.test(url)) return url;
			if (url.indexOf(baseRoot) === 0) return url;
			if (url.charAt(0) === '/') return url;
			return baseRoot + url.replace(/^\/+/, '');
		}

		function getSnippet(content, query) {
			var plain = (content || '').replace(/\s+/g, ' ').trim();
			if (!plain) return '';
			var lower = plain.toLowerCase();
			var keywordIndex = lower.indexOf(query);
			if (keywordIndex < 0) return plain.slice(0, 100);
			var start = Math.max(0, keywordIndex - 25);
			var end = Math.min(plain.length, keywordIndex + 75);
			return (start > 0 ? '…' : '') + plain.slice(start, end) + (end < plain.length ? '…' : '');
		}

		function setResultHtml(html) {
			results.innerHTML = html;
			results.hidden = false;
			docsTree.style.display = 'none';
		}

		function resetSearchView() {
			results.innerHTML = '';
			results.hidden = true;
			docsTree.style.display = '';
		}

		async function loadIndex() {
			if (indexedPosts.length) return indexedPosts;
			if (!loadingPromise) {
				loadingPromise = fetch('<%- url_for('search.json', { relative: true }) %>')
					.then(function (response) {
						if (!response.ok) throw new Error('Search index request failed');
						return response.json();
					})
					.then(function (payload) {
						var records = Array.isArray(payload) ? payload : (payload.posts || []);
						indexedPosts = records
							.map(function (item) {
								return {
									title: item.title || '',
									content: item.content || '',
									url: item.url || item.path || ''
								};
							})
							.filter(function (item) {
								return item.url;
							});
						return indexedPosts;
					});
			}
			return loadingPromise;
		}

		input.addEventListener('input', async function () {
			var rawQuery = input.value || '';
			var query = normalize(rawQuery.trim());
			if (!query) {
				resetSearchView();
				return;
			}

			setResultHtml('<div class="kira-search-state">正在搜索...</div>');

			try {
				var posts = await loadIndex();
				var matched = posts.filter(function (item) {
					return normalize(item.title).indexOf(query) !== -1 || normalize(item.content).indexOf(query) !== -1;
				}).slice(0, 20);

				if (!matched.length) {
					setResultHtml('<div class="kira-search-state">没有找到匹配内容</div>');
					return;
				}

				var html = matched.map(function (item) {
					var title = escapeHtml(item.title || '未命名文章');
					var snippet = escapeHtml(getSnippet(item.content, query));
					var href = escapeHtml(resolveUrl(item.url));
					return '<a class="kira-search-item" href="' + href + '"><div class="kira-search-item-title">' + title + '</div><div class="kira-search-item-snippet">' + snippet + '</div></a>';
				}).join('');

				setResultHtml(html);
			} catch (error) {
				setResultHtml('<div class="kira-search-state">搜索索引加载失败，请稍后重试</div>');
			}
		});
	})();
</script>
